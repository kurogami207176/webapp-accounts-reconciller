# ── Local development environment variables ──────────────────────────────────
# Copy this file to .env and fill in values for local development.
# docker-compose.yml picks up .env automatically.
# For running outside Docker (bin/run-local.sh), source this file first.

# Flask
SECRET_KEY=dev-secret-change-me-at-least-32-chars
ENVIRONMENT=development

# Database — local Postgres via docker-compose
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/appdb

# S3 — local via LocalStack
S3_BUCKET_NAME=local-reconciler
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Cognito — fill in from your Cognito stack outputs for real auth locally
# Leave blank to skip auth verification (useful for UI testing without Cognito)
COGNITO_REGION=ap-southeast-2
COGNITO_USER_POOL_ID=
COGNITO_WEB_CLIENT_ID=
COGNITO_MOBILE_CLIENT_ID=
COGNITO_HOSTED_UI_URL=

# Local dev auth bypass — only active when ENVIRONMENT=development
# Set to "admins" to browse as an admin, or "branch-manila" etc. for a branch user.
# Leave empty to require real Cognito authentication.
DEV_BYPASS_AUTH=

# ECS task triggering — not needed locally (tasks fall back to in-process threads)
# Uncomment and fill in if you want to test real ECS task triggering locally.
# ECS_CLUSTER_NAME=webapp-accounts-reconciller-production
# ECS_TASK_DEFINITION=webapp-accounts-reconciller-production
# ECS_TASK_SUBNETS=subnet-xxxxxxxx,subnet-yyyyyyyy
# ECS_TASK_SECURITY_GROUPS=sg-xxxxxxxx
# ECS_CONTAINER_NAME=app
